Windows Registry Editor Version 5.00

; =============================================
; AeroPKG — Remove context menu entries
; =============================================

[-HKEY_CURRENT_USER\Software\Classes\Applications\AeroPKG.exe]
[-HKEY_CURRENT_USER\Software\Classes\.pkg\OpenWithList\AeroPKG.exe]
[-HKEY_CURRENT_USER\Software\Classes\.pkg\shell\AeroPKG]
